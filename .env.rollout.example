# Rollout-oriented feature toggles (safe defaults)
FEATURE_REFERRAL=false
FEATURE_REFERRAL_PAYOUTS=false
FEATURE_SUPPORT=false
FEATURE_SUPPORT_CHAT_POLLING=false
FEATURE_SUPPORT_SLA=false
FEATURE_KYC=false
FEATURE_KYC_OPTIONAL=true
FEATURE_RATE_LIMIT_STRICT=false
FEATURE_AUDIT_STRICT=false

# Country policy for KYC (comma separated ISO-like codes)
KYC_REQUIRED_COUNTRIES=

# Worker safety knobs
TOPUP_WORKER_POLL_SECONDS=15
TOPUP_RUNNING_TIMEOUT_SECONDS=180

# Email delivery mode (pick one):
# 1) Local SMTP mode (recommended for self-hosted without third-party API)
EMAIL_FROM=noreply@cloud-mine.com
TEAM_APPLICATIONS_TO=admin@cloud-mine.com
EMAIL_SMTP_HOST=127.0.0.1
EMAIL_SMTP_PORT=25
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_SMTP_USE_TLS=false
EMAIL_SMTP_STARTTLS=false
EMAIL_SMTP_TIMEOUT_SECONDS=20

# 2) External HTTP API mode (optional, leave empty for local SMTP)
EMAIL_API_URL=
EMAIL_API_TOKEN=
EMAIL_API_TIMEOUT_SECONDS=20
